{
  "$schema": "https://schema.tauri.app/config/1",
  "package": {
    "productName": "OVC Desktop",
    "version": "0.1.0"
  },
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "http://127.0.0.1:18741",
    "distDir": "../web"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": true
      },
      "path": {
        "all": true
      },
      "dialog": {
        "all": true
      }
    },
    "windows": [
      {
        "title": "OVC",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "bundle": {
      "active": false,
      "targets": ["dmg"],
      "identifier": "com.ovc.desktop"
    },
    "security": {
      "csp": null
    }
  }
}
