VECTOR_DIM=384
SIMPLE_DB_URL=sqlite:///./src/ovc.db
OFFLINE_MODE=true

# Auth / DB (Postgres)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/ovc
DATABASE_URL=sqlite:///./src/ovc.db
SECRET_KEY=CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE_ME
ACCESS_TOKEN_EXPIRES_MIN=15
REFRESH_TOKEN_EXPIRES_DAYS=30
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=60
RATE_LIMIT_LOGIN_PER_MIN=10
PASSWORD_MIN_LENGTH=6
PASSWORD_REQUIRE_UPPER=false
PASSWORD_REQUIRE_LOWER=false
PASSWORD_REQUIRE_DIGIT=false
PASSWORD_REQUIRE_SYMBOL=false
EMAIL_FROM=no-reply@ovc.local
EMAIL_BACKEND=mock

# Desktop / auth mode
AUTH_MODE=local
DESKTOP_MODE=false

# Optional Supabase (used when AUTH_MODE=supabase or both)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_ISSUER=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUD=authenticated

# Sync engine (for desktop local-first -> remote sync)
SYNC_ENABLED=false
SYNC_REMOTE_BASE_URL=
SYNC_BEARER_TOKEN=
SYNC_POLL_SECONDS=15
SYNC_OUTBOX_MAX=10000
SYNC_BATCH_SIZE=100
SYNC_REQUEST_TIMEOUT_SECONDS=12
SYNC_PULL_ENABLED=true

# Public hosting via Cloudflare Tunnel (template values)
PUBLIC_BASE_URL=https://<YOUR_HOSTNAME>
CORS_ORIGINS=["https://<YOUR_HOSTNAME>","http://127.0.0.1:8000"]
COOKIE_DOMAIN=<YOUR_HOSTNAME>
COOKIE_SECURE=true
CLOUDFLARED_CONFIG_PATH=/absolute/path/to/config.yml
# optional
# RATE_LIMIT_LOGIN_PER_MIN=10
